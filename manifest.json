{
    "name": "TurboTune",
    "version": "0.3.0",
    "manifest_version": 3,
    "description": "Take control of playback speed on YouTube and any HTML5 video. Slider, presets, keyboard shortcuts, on-screen overlay, and auto-apply.",
    "action": {
        "default_popup": "main.html",
        "default_icon": {
            "128": "logo.png"
        }
    },
    "icons": {
        "128": "logo.png"
    },
    "permissions": [
        "activeTab",
        "storage"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle",
            "all_frames": true
        }
    ],
    "commands": {
        "speed-up": {
            "suggested_key": {
                "default": "Alt+Period"
            },
            "description": "Increase playback speed"
        },
        "speed-down": {
            "suggested_key": {
                "default": "Alt+Comma"
            },
            "description": "Decrease playback speed"
        },
        "speed-reset": {
            "suggested_key": {
                "default": "Alt+0"
            },
            "description": "Reset playback speed to 1x"
        }
    },
    "background": {
        "service_worker": "background.js"
    }
}
